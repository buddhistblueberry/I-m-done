# LOCAL DEV ONLY — do NOT commit real values to the repo.
# Copy this file to `keystore.properties` in the project root and fill in
# the path to your release.keystore. It is read by app/build.gradle.kts
# so `./gradlew assembleRelease` signs locally with the same key CI uses.
#
# The real keystore + passwords live in GitHub Actions secrets in CI:
#   KEYSTORE_BASE64, KEYSTORE_PASSWORD, KEY_ALIAS, KEY_PASSWORD
#
# Add `keystore.properties` and `release.keystore` to your .gitignore.

storeFile=release.keystore
storePassword=super_secret_store_pass_2024
keyAlias=mariocart
keyPassword=super_secret_store_pass_2024
